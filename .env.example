# Windhelm Guard Environment Configuration Example

# Discord Bot Token
DISCORD_TOKEN="your_discord_bot_token_here"

# Multi-API Load Balancer Options (comma-separated Groq API keys)
GROQ_API_KEYS="gsk_key1,gsk_key2"

# (Optional) Comma-separated list of server (guild) IDs where the bot is allowed to run.
ALLOWED_GUILDS="123456789012345678"

# The ID of the private channel where the bot will send its intelligence/threat reports.
MOD_CHANNEL_ID="123456789012345678"

# (Optional) The ID of the channel where the bot will send general server event logs.
LOG_CHANNEL_ID="123456789012345678"

# The Discord User ID of the Jarl (Server Owner) who can bypass mentions/cooldowns.
OWNER_ID="123456789012345678"

# (Optional) Comma-separated list of channel IDs where NSFW content checks are bypassed.
NSFW_ALLOWED_CHANNELS="123456789012345678"
